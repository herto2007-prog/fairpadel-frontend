generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════════

enum UserStatus {
  NO_VERIFICADO
  ACTIVO
  INACTIVO
  SUSPENDIDO
}

enum RoleName {
  jugador
  organizador
  admin
}

// ═══════════════════════════════════════════════════════
// MODELS
// ═══════════════════════════════════════════════════════

model User {
  id            String     @id @default(uuid())
  email         String     @unique
  passwordHash  String     @map("password_hash")
  nombre        String
  apellido      String
  documento     String     @unique // C.I. Paraguaya
  telefono      String
  status        UserStatus @default(NO_VERIFICADO)
  
  // Timestamps
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  
  // Relations
  roles         UserRole[]
  
  @@map("users")
}

model Role {
  id        String     @id @default(uuid())
  name      RoleName   @unique
  createdAt DateTime   @default(now()) @map("created_at")
  
  // Relations
  users     UserRole[]
  
  @@map("roles")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")
  
  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  
  @@unique([userId, roleId])
  @@map("user_roles")
}
